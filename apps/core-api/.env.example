PORT=3000
NODE_ENV=development

DATABASE_URL="postgresql://shgap:shgap_dev_password@localhost:55432/shgap?schema=public"
REDIS_URL="redis://localhost:6379"

# Generate real secrets for anything beyond local dev, e.g.: openssl rand -hex 32
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_REQUESTS_PER_WINDOW=5
OTP_RATE_LIMIT_WINDOW_SECONDS=3600

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=shgap
MINIO_SECRET_KEY=shgap_dev_password
MINIO_BUCKET=shgap-product-images
MINIO_PUBLIC_URL="http://localhost:9000/shgap-product-images"

CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ml-services' /categorize endpoint (T08) — proxied through core-api since
# ml-services isn't exposed directly to the frontend.
ML_SERVICES_URL="http://localhost:8001"

# notification-service's dispatch endpoint (T13) — the auth flow's OTP send
# goes through here instead of a raw SMS gateway call; see
# src/auth/sms/notification-service.provider.ts and ADR-0022.
NOTIFICATION_SERVICE_URL="http://localhost:3001"
