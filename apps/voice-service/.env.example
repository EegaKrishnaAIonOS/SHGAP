PORT=8002

# Groq (STT + LLM) and Sarvam (TTS) — see ADR-0019 for why these replace
# ADR-0006's original Bhashini/AI4Bharat pick. Get keys at
# console.groq.com and dashboard.sarvam.ai — never commit real values here.
GROQ_API_KEY=
SARVAM_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo
SARVAM_TTS_MODEL=bulbul:v2

REDIS_URL="redis://localhost:6379"
VOICE_SESSION_TTL_SECONDS=900

# core-api base URL the action dispatcher calls, forwarding the caller's own
# JWT access token (no separate service credential — see ADR-0019).
CORE_API_BASE_URL="http://localhost:3000"
