PORT=8001

# Plain libpq DSN (no Prisma-style `?schema=` suffix) — ml-services connects
# directly to Postgres to read the category taxonomy (T08); see ADR-0017.
DATABASE_URL="postgresql://shgap:shgap_dev_password@localhost:55432/shgap"

# Ungated multilingual sentence-embedding model (T08) — ai4bharat/indic-bert
# is gated on HuggingFace and unusable without an authenticated account.
EMBEDDING_MODEL_NAME="sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
CATEGORY_CACHE_TTL_SECONDS=300
