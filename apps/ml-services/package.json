{
  "name": "@shgap/ml-services",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "venv": "python -m venv .venv",
    "install:deps": "python -m pip install -r requirements-dev.txt",
    "dev": "python -m uvicorn app.main:app --reload --port 8001",
    "build": "python -m compileall app",
    "lint": "python -m ruff check .",
    "test": "python -m pytest"
  }
}
