PORT=3001
NODE_ENV=development

DATABASE_URL="postgresql://shgap:shgap_dev_password@localhost:55432/shgap"
REDIS_URL="redis://localhost:6379"

# All provider credentials below are optional — leave unset to use each
# channel's console/dev-stub provider (logs instead of sending), see
# ADR-0011/ADR-0022. Never commit real values here.

# MSG91 (SMS, also powers OTP) — DLT-registered template IDs referenced by
# apps/notification-service/src/notifications/templates/templates.ts must be
# registered under this account (see MSG91_SENDER_ID's DLT entity).
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# WhatsApp Business (Meta Cloud API) — templates referenced in templates.ts
# must be pre-approved under this phone number's WhatsApp Business account.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Exotel (voice/IVR alerts)
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_CALLER_ID=
EXOTEL_VOICE_APPLET_URL=

# Amazon SES (email)
AWS_SES_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=
